algoritmo "Nome do Programa"
// Crie um programa usando o "PARA" que calcular a média de 4 números inseridos pelo usuário.
var

contador, soma , media, numero: real

inicio
para contador de 1 ate 4 faca
    escreval ("Digite o ", contador, "número")
    leia(numero)
    soma <- soma + numero
    media <- soma / 4

fimpara
escreva("A média dos números é: ", media)

fimalgoritmo