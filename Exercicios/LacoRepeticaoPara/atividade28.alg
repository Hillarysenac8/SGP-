algoritmo "Nome do Programa"
// Crie um programa usando o "PARA" que mostre os números de 1 a 100 que são divisíveis por 7.
var

contador : inteiro

inicio
para contador de 1 ate 100 faca
se contador mod 7 = 0 entao
    escreval ("Os números divisíveis por 7 são: ", contador)
    fimse

fimpara
fimalgoritmo