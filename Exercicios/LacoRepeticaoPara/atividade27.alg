algoritmo "Nome do Programa"
// Crie um programa usando o "PARA" que mostre a contagem dos números múltiplos de 3 de 1 a 30.
var

contador : inteiro

inicio
para contador de 1 ate 30 faca
    se (contador % 3 = 0) entao
        escreval (" O ", contador, " é multiplo de 3 ")
    fimse

fimpara

fimalgoritmo