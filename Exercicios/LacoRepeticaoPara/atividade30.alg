algoritmo "Nome do Programa"
// Crie um programa usando o "PARA" que calcular a soma de 3 números digitado pelo usuário.
var

contador, numero, soma : real

inicio

para contador de 1 ate 3 faca
    escreval ("Digite o ", contador, "número")
    leia(numero)
    soma <- soma + numero

fimpara
escreva("A soma dos números é: ", soma)
fimalgoritmo