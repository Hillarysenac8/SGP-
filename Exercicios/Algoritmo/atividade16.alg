algoritmo "atividade16"
//Crie um programa que verifique o número que o usuário digite
//qual será positivo ou negativo
var

numero : inteiro

inicio


escreva ("Digite o número")
leia(numero)

se (numero>0) entao
escreval("Positivo")

senao se (numero=0) entao
escreval("Número neutro")

senao
escreval("Negativo")
fimse
fimse

fimalgoritmo