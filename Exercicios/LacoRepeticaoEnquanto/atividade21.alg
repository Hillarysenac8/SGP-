algoritmo "Nome do Programa"


var

contador: inteiro
soma: inteiro

inicio

soma <- 0
contador <- 1

enquanto (contador <= 100) faca
soma <- soma + contador
    escreval (" Adicionando: ", contador, " Igual á: ", soma)
    contador <- contador + 1

fimenquanto

escreval("Resultado: ", soma)

fimalgoritmo